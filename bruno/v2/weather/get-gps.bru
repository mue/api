meta {
  name: Reverse Geocode (GPS)
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/v2/gps
  body: none
  auth: none
}

params:query {
  latitude: 51.5074
  longitude: -0.1278
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("returns an array", function() {
    expect(res.body).to.be.an("array");
  });

  test("missing coords returns 400", function() {
    // Run separately: GET /v2/gps (no params) → 400
  });
}
