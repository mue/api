meta {
  name: Increment Image Download
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/v2/images/{{imageId}}/download
  body: none
  auth: none
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("returns download count", function() {
    expect(res.body).to.have.property("downloads");
    expect(res.body.downloads).to.be.a("number");
    expect(res.body.downloads).to.be.greaterThan(0);
  });
}
